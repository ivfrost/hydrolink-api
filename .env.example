# .env.example
# Copy this file to .env and fill in real values before running the app locally.
#   cp .env.example .env
#
# No defaults are set anywhere (Spring properties or docker-compose) — every
# variable below is required. Missing any of them will cause a fail-fast error
# at startup (Spring) or docker compose refusing to start the service.

# --- Secrets ---
# Generate each with: openssl rand -base64 32
JWT_SECRET=
RECOVERY_SECRET=
DEVICE_SECRET=
PROVISIONING_SECRET=

# --- MQTT ---
MQTT_BROKER_URL=tcp://localhost:1883
API_MQTT_CLIENT_ID=hydro-api-client
API_MQTT_USERNAME=hydro-api-user
API_MQTT_PASSWORD=
# Generate with: base64 -w0 mqtt_private_key.der
MQTT_PRIVATE_KEY_B64=

# --- Database ---
# Must match docker-compose.dev.yml's postgres service — these values create
# the Postgres role/database on first container init AND are what the app
# connects with, so they must be identical on both sides.
DB_URL=jdbc:postgresql://localhost:5432/hydrodb-dev
DB_USERNAME=admin
DB_PASSWORD=
DB_NAME=hydrodb-dev

# --- RabbitMQ ---
# Must match docker-compose.dev.yml's rabbitmq service credentials
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=

# --- Seed Data ---
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_DEVICE1_KEY=
SEED_DEVICE1_SECRET=
SEED_DEVICE2_KEY=
SEED_DEVICE2_SECRET=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173